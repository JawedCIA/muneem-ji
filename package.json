{
  "name": "muneemji",
  "version": "1.0.0",
  "private": true,
  "description": "Muneem Ji - Aapka Digital Muneem. Self-hosted GST billing & business management for Indian small businesses.",
  "scripts": {
    "install:all": "npm i && cd client && npm i && cd ../server && npm i",
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "cd client && npm run build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "seed": "cd server && npm run seed",
    "db:migrate": "node server/db/migrate.js",
    "db:status": "node server/db/migrate.js status",
    "test:e2e": "node server/test/e2e.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v",
    "docker:migrate": "docker compose --profile tools run --rm migrate",
    "docker:db:status": "docker compose --profile tools run --rm migrate-status"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3"
  }
}
