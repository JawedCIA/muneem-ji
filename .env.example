# Muneem Ji environment configuration (production)
# Copy to .env and edit as needed. Docker Compose picks these up automatically.

# Public host port for the web UI (defaults to 3001 inside the container)
MUNEEMJI_PORT=3001

# Pin the JWT secret across container rebuilds (recommended for production).
# If unset, a random one is generated and persisted to /app/data/.jwt-secret.
# JWT_SECRET=replace-with-64-random-hex-chars

# Comma-separated list of allowed origins (default: http://localhost:5173,http://localhost:5174).
# In production behind a reverse proxy on a real domain, set this to your domain.
# CORS_ORIGIN=https://billing.yourshop.com

# Daily auto-backup configuration
# BACKUP_HOUR=2
# BACKUP_RETENTION_DAYS=7

# Set to 1 ONLY if accessing over plain HTTP (not recommended).
# Without this, session cookies require HTTPS in production.
# COOKIE_INSECURE=0
